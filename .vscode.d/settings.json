{
  "chat.editor.wordWrap": "on",
  "diffEditor.experimental.showEmptyDecorations": true,
  "diffEditor.ignoreTrimWhitespace": false,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.acceptSuggestionOnEnter": "off",
  "editor.aiStats.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.dragAndDrop": false,
  "editor.find.seedSearchStringFromSelection": "selection",
  "editor.foldingImportsByDefault": true,
  "editor.fontFamily": "'Fira Code', FiraCode, 'FiraCode Nerd Font', Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.formatOnSave": true,
  "editor.guides.bracketPairs": true,
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.suppressSuggestions": true,
  "editor.insertSpaces": true,
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 80,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.showSlider": "always",
  "editor.minimap.size": "fill",
  "editor.mouseWheelZoom": true,
  "editor.multiCursorModifier": "alt",
  "editor.quickSuggestions": {
    "comments": "off",
    "other": "off",
    "strings": "off"
  },
  "editor.renderLineHighlight": "all",
  "editor.renderLineHighlightOnlyWhenFocus": true,
  "editor.renderWhitespace": "all",
  "editor.rulers": [
    {
      "column": 80
    },
    {
      "column": 120
    }
  ],
  "editor.stickyTabStops": true,
  "editor.suggest.insertMode": "replace",
  "editor.suggest.matchOnWordStartOnly": false,
  "editor.suggest.preview": true,
  "editor.suggest.selectionMode": "whenTriggerCharacter",
  "editor.suggest.showIcons": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.snippetsPreventQuickSuggestions": true,
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.wrappingIndent": "indent",
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "problems.showCurrentInStatus": true,
  "scm.alwaysShowActions": true,
  "scm.alwaysShowRepositories": true,
  "scm.inputFontFamily": "editor",
  "scm.inputFontSize": 12,
  "search.showLineNumbers": true,
  "search.smartCase": true,
  "search.sortOrder": "modified",
  "telemetry.editStats.details.enabled": false,
  "telemetry.editStats.enabled": false,
  "telemetry.feedback.enabled": false,
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.rightClickBehavior": "default",
  "terminal.integrated.scrollback": 9000,
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.shellIntegration.history": 500,
  "terminal.integrated.tabs.showActiveTerminal": "always",
  "window.autoDetectColorScheme": true,
  "window.commandCenter": true,
  "window.dialogStyle": "custom",
  "window.menuBarVisibility": "compact",
  "window.title": "${dirty}${activeFolderShort}${separator}${activeEditorShort}  <-  ${profileName}@${rootName}",
  "window.titleBarStyle": "custom",
  "window.titleSeparator": "/",
  "workbench.activityBar.location": "top",
  "workbench.editor.centeredLayoutFixedWidth": true,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.pinnedTabSizing": "shrink",
  "workbench.editor.revealIfOpen": true,
  "workbench.editor.tabSizing": "shrink",
  "workbench.editor.wrapTabs": true
}
